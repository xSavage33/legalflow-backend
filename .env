# LegalFlow - Development Environment Variables
# IMPORTANT: Change these values in production!

# Django Secret Keys (generate new ones for production)
SECRET_KEY=dev-secret-key-change-in-production-abc123xyz789
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production-def456uvw012

# Debug mode (set to false in production)
DEBUG=true

# Allowed Hosts (include Docker service names for internal communication)
ALLOWED_HOSTS=localhost,127.0.0.1,api_gateway,iam_service,matter_service,document_service,time_tracking_service,billing_service,calendar_service,client_portal_service,analytics_service

# Email Configuration (optional for development)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Database passwords (used by docker-compose)
POSTGRES_PASSWORD=postgres

# Redis
REDIS_URL=redis://redis:6379/0
