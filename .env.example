# ====================
# LEGALFLOW ENVIRONMENT VARIABLES
# ====================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ====================
# GENERAL SETTINGS
# ====================
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# ====================
# DATABASE CREDENTIALS - IAM SERVICE
# ====================
IAM_DB_NAME=iam_db
IAM_DB_USER=iam_user
IAM_DB_PASSWORD=iam_password_change_me

# ====================
# DATABASE CREDENTIALS - MATTER SERVICE
# ====================
MATTER_DB_NAME=matter_db
MATTER_DB_USER=matter_user
MATTER_DB_PASSWORD=matter_password_change_me

# ====================
# DATABASE CREDENTIALS - DOCUMENT SERVICE
# ====================
DOCUMENT_DB_NAME=document_db
DOCUMENT_DB_USER=document_user
DOCUMENT_DB_PASSWORD=document_password_change_me

# ====================
# DATABASE CREDENTIALS - TIME TRACKING SERVICE
# ====================
TIME_DB_NAME=time_db
TIME_DB_USER=time_user
TIME_DB_PASSWORD=time_password_change_me

# ====================
# DATABASE CREDENTIALS - BILLING SERVICE
# ====================
BILLING_DB_NAME=billing_db
BILLING_DB_USER=billing_user
BILLING_DB_PASSWORD=billing_password_change_me

# ====================
# DATABASE CREDENTIALS - CALENDAR SERVICE
# ====================
CALENDAR_DB_NAME=calendar_db
CALENDAR_DB_USER=calendar_user
CALENDAR_DB_PASSWORD=calendar_password_change_me

# ====================
# DATABASE CREDENTIALS - CLIENT PORTAL SERVICE
# ====================
PORTAL_DB_NAME=portal_db
PORTAL_DB_USER=portal_user
PORTAL_DB_PASSWORD=portal_password_change_me

# ====================
# DATABASE CREDENTIALS - ANALYTICS SERVICE
# ====================
ANALYTICS_DB_NAME=analytics_db
ANALYTICS_DB_USER=analytics_user
ANALYTICS_DB_PASSWORD=analytics_password_change_me

# ====================
# REDIS
# ====================
REDIS_URL=redis://localhost:6379/0

# ====================
# CELERY
# ====================
CELERY_BROKER_URL=redis://localhost:6379/9
CELERY_RESULT_BACKEND=redis://localhost:6379/9

# ====================
# EMAIL SETTINGS
# ====================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@legalflow.com

# ====================
# CORS SETTINGS
# ====================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ====================
# FRONTEND URLS
# ====================
ADMIN_PORTAL_URL=http://localhost:3000
CLIENT_PORTAL_URL=http://localhost:3001

# ====================
# FILE STORAGE
# ====================
MEDIA_ROOT=/app/media
MAX_UPLOAD_SIZE_MB=50
